{
  "name": "drawdowndesk",
  "version": "0.1.0",
  "private": true,
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently \"npx convex dev\" \"next dev --turbopack\"",
    "dev:clean": "npx rimraf .next && concurrently \"npx convex dev\" \"next dev --turbopack\"",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ignore-pattern release/** --ignore-pattern dist-electron/** --ignore-pattern convex/_generated/**",
    "electron:compile": "tsc -p electron/tsconfig.json",
    "electron:dev": "npm run electron:compile && concurrently \"npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:start": "npm run electron:compile && electron .",
    "electron:make": "npm run build && npm run electron:compile && electron-forge package --platform=win32 --arch=x64 && node -e \"const fs=require('fs');const path=require('path');const src='out/DrawdownDesk-win32-x64';const dest='release';if(fs.existsSync(dest))fs.rmSync(dest,{recursive:true});fs.cpSync(src,dest,{recursive:true});console.log('Copied to release/')\"",
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "test:report": "playwright show-report",
    "test:install": "playwright install chromium",
    "test:reset": "echo 'Tests authenticate fresh on each run - no session to reset'"
  },
  "dependencies": {
    "@convex-dev/auth": "^0.0.91",
    "@radix-ui/react-accordion": "^1.2.11",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.12",
    "@radix-ui/react-tooltip": "^1.2.7",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.25.4",
    "electron-store": "^11.0.2",
    "lucide-react": "^0.576.0",
    "next": "^16.2.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "recharts": "^2.15.4",
    "tailwind-merge": "^3.3.1",
    "yahoo-finance2": "^3.13.1"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.5.0",
    "@electron-forge/maker-zip": "^7.5.0",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20.19.35",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "dotenv": "^17.3.1",
    "electron": "^40.6.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.7",
    "react-grab": "^0.1.23",
    "rimraf": "^6.1.3",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.3.5",
    "typescript": "^5",
    "wait-on": "^9.0.4"
  },
  "config": {
    "forge": "./forge.config.ts"
  },
  "overrides": {
    "glob": "^13.0.0",
    "tar": "^7.0.0",
    "serialize-javascript": "^7.0.0",
    "tmp": "^0.2.3"
  }
}
